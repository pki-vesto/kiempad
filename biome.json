{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "files": {
    "maxSize": 2097152,
    "includes": ["src/**", "tests/**", "public/kiempad-sw.js", "index.html"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  }
}
