{
  "name": "kiempad",
  "version": "0.1.0",
  "private": true,
  "description": "Kiempad — persoonlijke, centraal versleutelde ondersteuningstool voor een IVF/ICSI-traject (privégebruik, geen medisch hulpmiddel).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false .",
    "typecheck": "tsc --noEmit",
    "assets:check": "node scripts/check-no-external-assets.mjs",
    "secrets:check": "node scripts/check-secrets.mjs",
    "fixtures:check": "node scripts/check-sensitive-fixtures.mjs",
    "deps:review": "node scripts/dependency-review.mjs",
    "backlog:health": "node scripts/backlog-health.mjs",
    "goals:score": "node scripts/goal-score.mjs",
    "drill:backup": "vitest run tests/backupRestoreDrill.test.ts",
    "smoke:offline": "node scripts/offline-smoke.mjs",
    "smoke:central": "node scripts/central-browser-smoke.mjs",
    "backend:central": "tsx src/server/centralBackendCli.ts",
    "deploy:tailscale": "scripts/deploy-tailscale.sh",
    "smoke:tailscale": "scripts/smoke-tailscale.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
