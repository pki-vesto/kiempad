{
  "name": "kiempad",
  "version": "0.1.0",
  "private": true,
  "description": "Kiempad — persoonlijke, local-first ondersteuningstool voor een IVF/ICSI-traject (privégebruik, geen medisch hulpmiddel).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^2.0.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
