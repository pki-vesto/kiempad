# Kiempad — voorbeeldconfiguratie.
# Kopieer naar `.env` (NIET committen). Voor de centrale encrypted API is alleen een
# private API-URL nodig; medische inhoud blijft client-side versleuteld. Laat een
# regel leeg/uitgecommentarieerd om de functie uit te zetten.

# --- Centrale encrypted opslag (AANBEVOLEN VOOR NIEUWE DATA) ---------------
# Start eerst `npm run backend:central` of de aparte backendcontainer.
# De user id is geen secret; hij scoped records aan de serverkant voor deze privé-app.
# De backend moet dezelfde id in KIEMPAD_CENTRAL_ALLOWED_USER_IDS toestaan; die
# server-side allowlist is de autoriteit.
# De backend moet ook de browser-origin van de PWA toestaan via
# KIEMPAD_CENTRAL_ALLOWED_ORIGINS.
# Zonder VITE_KIEMPAD_CENTRAL_API_URL valt de PWA terug op de legacy lokale
# IndexedDB-kluis op dit toestel.
# VITE_KIEMPAD_CENTRAL_API_URL=http://127.0.0.1:8099
# VITE_KIEMPAD_CENTRAL_USER_ID=kiempad-private-user

# --- AI-samenvatting (OPTIONEEL, opt-in) -----------------------------------
# Alleen nodig als je de research-samenvatfunctie aanzet. Zonder sleutel blijft
# de hele AI-laag uit. Zie docs/adr/0003 en SECURITY.md voor de waarborgen.
# De sleutel wordt versleuteld in de lokale opslag bewaard, nooit in de repo.
# KIEMPAD_AI_PROVIDER=          # bv. anthropic | openai | (leeg = uit)
# KIEMPAD_AI_API_KEY=           # je eigen abonnementssleutel; lokaal, versleuteld
# KIEMPAD_AI_MODEL=             # bv. claude-haiku-4-5 (snel/goedkoop voor samenvatten)

# --- Ontwikkeling ----------------------------------------------------------
# Poort voor de lokale dev-server (Vite). Alleen voor development.
KIEMPAD_DEV_PORT=5173
