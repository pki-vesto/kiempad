FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

ENV KIEMPAD_CENTRAL_HOST=0.0.0.0
ENV KIEMPAD_CENTRAL_PORT=8099
ENV KIEMPAD_CENTRAL_PERSISTENCE_FILE=/data/kiempad-central-db.json
ENV KIEMPAD_CENTRAL_ALLOWED_USER_IDS=kiempad-private-user
ENV KIEMPAD_CENTRAL_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost:4174,http://127.0.0.1:4174

EXPOSE 8099

CMD ["npm", "run", "backend:central"]
